# EVM RPC endpoints (one per chain this deployment needs)
RPC_1=https://example.ethereum-mainnet.quiknode.pro
RPC_11155111=https://example.ethereum-sepolia.quiknode.pro
RPC_42161=https://example.arb-mainnet.quiknode.pro
RPC_421614=https://example.arb-sepolia.quiknode.pro
RPC_8453=https://example.base-mainnet.quiknode.pro
RPC_84532=https://example.base-sepolia.quiknode.pro
RPC_300=https://example.zksync-sepolia.quiknode.pro
RPC_324=https://example.zksync-mainnet.quiknode.pro

# Avail — single network per deployment
AVAIL_RPC_URL=https://turing-rpc.avail.so/rpc
AVAIL_NETWORK=turing

# Postgres DB connection string
DATABASE_URL=postgresql://pg_user:pg_password@localhost:5432/vectorx-indexer

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Log level
RUST_LOG=info
